---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';

export const getStaticPaths = (async () => {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, community, location, category, date } = entry.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title}>
  <article class="case-study">
    <header class="case-header">
      <div class="u-container">
        <div class="header-content">
          <div class="category-badge">{category.replace('-', ' ')}</div>
          <h1 class="u-heading case-title" data-sy-reveal="words">{title}</h1>
          <p class="u-text case-description" data-sy-reveal="lines">{description}</p>
          <div class="meta">
            <div class="meta-item">
              <span class="meta-label">Community</span>
              <span class="meta-value">{community}</span>
            </div>
            {location && (
              <div class="meta-item">
                <span class="meta-label">Location</span>
                <span class="meta-value">{location}</span>
              </div>
            )}
            <div class="meta-item">
              <span class="meta-label">Published</span>
              <span class="meta-value">{formattedDate}</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="case-content">
      <div class="u-container">
        <div class="content-wrapper">
          <Content />
        </div>
      </div>
    </div>

    <footer class="case-footer">
      <div class="u-container">
        <div class="footer-content">
          <h2 class="u-heading footer-title" data-sy-reveal="words">
            Interested in building something similar?
          </h2>
          <p class="u-text footer-text" data-sy-reveal="lines">
            Join the early community to connect with others building citizen-owned infrastructure.
          </p>
          <div class="footer-actions">
            <Button title="Join the Early Community" url="/#early" arrow />
            <Button title="← Back to Case Studies" url="/cases" color="secondary" />
          </div>
        </div>
      </div>
    </footer>
  </article>
</Layout>

<style>
  .case-study {
    padding-top: 4rem;
  }

  .case-header {
    padding: 4rem 0 3rem;
    background: linear-gradient(
      180deg,
      rgba(var(--rgb-brand-3), 0.05) 0%,
      rgba(var(--rgb-bg), 1) 100%
    );
  }

  .header-content {
    max-width: 48rem;
    margin: 0 auto;
  }

  .category-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background: linear-gradient(
      135deg,
      rgba(var(--rgb-brand-1), 0.1) 0%,
      rgba(var(--rgb-brand-3), 0.1) 100%
    );
    color: var(--color-brand-1);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .case-title {
    --fs: 3rem;
    --lh: 1.1;
    margin-bottom: 1.5rem;

    @media (--mq-phone) {
      --fs: 2.25rem;
    }
  }

  .case-description {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
    margin-bottom: 2rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(var(--rgb-text), 0.1);
    border-bottom: 1px solid rgba(var(--rgb-text), 0.1);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-alt);
  }

  .meta-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .case-content {
    padding: 4rem 0;
  }

  .content-wrapper {
    max-width: 42rem;
    margin: 0 auto;

    :global(h2) {
      --fs: 2rem;
      --fw: 600;
      --lh: 1.3;
      margin: 3rem 0 1rem;
      color: var(--color-text);

      &:first-child {
        margin-top: 0;
      }
    }

    :global(h3) {
      --fs: 1.5rem;
      --fw: 600;
      margin: 2rem 0 0.75rem;
      color: var(--color-text);
    }

    :global(p) {
      --fs: var(--font-size-md);
      --lh: 1.7;
      color: var(--color-text);
      margin: 1rem 0;
    }

    :global(ul),
    :global(ol) {
      margin: 1.5rem 0;
      padding-left: 1.5rem;

      :global(li) {
        --fs: var(--font-size-md);
        --lh: 1.7;
        margin: 0.5rem 0;
        color: var(--color-text);

        &::marker {
          color: var(--color-brand-1);
        }
      }
    }

    :global(strong) {
      font-weight: 600;
      color: var(--color-brand-1);
    }

    :global(blockquote) {
      margin: 2.5rem 0;
      padding: 1.5rem 2rem;
      border-left: 4px solid var(--color-brand-1);
      background: rgba(var(--rgb-brand-3), 0.05);
      border-radius: 0 0.5rem 0.5rem 0;

      :global(p) {
        --fs: 1.125rem;
        font-style: italic;
        color: var(--color-text-alt);
        margin: 0;
      }
    }

    :global(code) {
      background: rgba(var(--rgb-text), 0.05);
      padding: 0.2em 0.4em;
      border-radius: 0.25rem;
      font-family: 'Courier New', monospace;
      font-size: 0.9em;
    }
  }

  .case-footer {
    padding: 4rem 0 6rem;
    background: linear-gradient(
      180deg,
      rgba(var(--rgb-bg), 1) 0%,
      rgba(var(--rgb-brand-3), 0.05) 100%
    );
  }

  .footer-content {
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-title {
    --fs: 2rem;
    --lh: 1.2;

    @media (--mq-phone) {
      --fs: 1.75rem;
    }
  }

  .footer-text {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
  }

  .footer-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;

    @media (--mq-phone) {
      flex-direction: column;
      width: 100%;
    }
  }
</style>
