---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import GalleryText from "../components/GalleryText.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import Button from "../components/Button.astro";
import GL from "../components/GLNetwork.astro";
import GLPlaces from "../components/GlPlaces.astro";
import CaseCard from "../components/CaseCard.astro";
import ResearchCard from "../components/ResearchCard.astro";
import { getCollection } from 'astro:content';

// Get featured case studies and research
const allCases = await getCollection('cases');
const featuredCases = allCases
  .filter(c => c.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const allResearch = await getCollection('research');
const featuredResearch = allResearch
  .filter(r => r.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<Layout title="Home">
  <section id="overview">
    <HeroHome
      title="A new Internet, owned by citizens."
      subtitle="Reclaim your online experience: search engines, social networks, marketplaces, browsers—locally-operated, globally connected."
      cta={{
        title: "Join the Early Community",
        url: "#early",
      }}
      ctaSecondary={{
        title: "Read the Vision",
        url: "#vision",
      }}
    />
  </section>

  <section id="vision">
    <Introducing
      title="Reclaim your online experience from centralized platforms."
      text="Citinet provides everything you use online—browsers, search engines, social networks, marketplaces, messaging, email—but operated by citizens, not corporations."
      cta={{
        title: "Explore the Vision",
        url: "#vision",
      }}
    />

    <StepsTimeline
      title="What it's all about"
      items={[
        {
          title: "Local-first by design",
          text: "Your online infrastructure is operated nearby—not in distant corporate data centers—but connects you globally.",
        },
        {
          title: "Private by default",
          text: "No tracking, no profiling, no data harvesting.",
        },
        {
          title: "Community-powered",
          text: "Search engines, social networks, and marketplaces run on small, citizen-operated nodes.",
        },
      ]}
    />
  </section>

  <section id="ecosystem">
    <GalleryText
      title="Privacy. Independence. Community."
      text="Instead of relying on corporate search engines, social networks, and marketplaces, Citinet lets everyday people operate small, simple nodes—providing browsers, search, social, commerce—that contribute to a larger, citizen-owned network."
      cta={{
        title: "See the Story",
        url: "#vision",
      }}
      images={[
        {
          alt: "Local-first spaces",
          src: "/image-1.jpg",
          width: 6000,
          height: 4000,
        },
        {
          alt: "Private communication",
          src: "/image-2.jpg",
          width: 2689,
          height: 4032,
        },
        {
          alt: "Community connection",
          src: "/image-3.jpg",
          width: 3734,
          height: 5359,
        },
      ]}
      marqueeTexts={[
        "A new Internet, owned by citizens",
        "Local-first by design",
        "A network of networks",
        "Search, social, commerce—citizen-powered",
      ]}
    />

  <section id="principles">
    <Statements
      items={[
        {
          title: "Independence",
          text: "Citizens own their digital world.",
        },
        {
          title: "Privacy",
          text: "What you do stays yours.",
        },
        {
          title: "Transparency",
          text: "No hidden algorithms or extraction.",
        },
      ]}
    />
  </section>

  <TextMarquee
    class="marquee"
    texts={[
      "A new Internet, owned by citizens",
      "Local-first by design",
      "Privacy. Independence. Community.",
      "Search, social, commerce—citizen-powered",
    ]}
  />

  {featuredResearch.length > 0 && (
    <section id="research" class="research-preview">
      <div class="u-container">
        <div class="research-header">
          <h2 class="u-heading research-title" data-sy-reveal="words">
            Why we need this
          </h2>
          <p class="u-text research-subtitle" data-sy-reveal="lines">
            The problems are documented: surveillance, environmental damage, algorithmic manipulation, and the erosion of digital freedom.
          </p>
        </div>
        <div class="research-grid">
          {featuredResearch.map((researchItem) => (
            <ResearchCard research={researchItem} />
          ))}
        </div>
        <div class="research-cta">
          <Button title="Read More Research →" url="/research" color="secondary" />
        </div>
      </div>
    </section>
  )}

  {featuredCases.length > 0 && (
    <section id="cases" class="cases-preview">
      <div class="u-container">
        <div class="cases-header">
          <h2 class="u-heading cases-title" data-sy-reveal="words">
            Communities building the citizen-owned Internet
          </h2>
          <p class="u-text cases-subtitle" data-sy-reveal="lines">
            Real people operating search engines, social networks, and marketplaces in their neighborhoods and towns.
          </p>
        </div>
        <div class="cases-grid">
          {featuredCases.map((caseStudy) => (
            <CaseCard case={caseStudy} />
          ))}
        </div>
        <div class="cases-cta">
          <Button title="View All Case Studies →" url="/cases" color="secondary" />
        </div>
      </div>
    </section>
  )}

  <section id="faq">
    <Faqs
      title="A network of networks."
      mobileTitle="FAQs"
      subtitle="Citinet uses the physical Internet infrastructure, but replaces the centralized platforms dominating it."
      items={[
        {
          question: "What is Citinet?",
          answer:
            "Citinet is a complete, citizen-operated alternative to the centralized online experience. It includes browsers, search engines, social networks, marketplaces, messaging, email, and storage—everything you use online, but locally-operated and globally connected.",
        },
        {
          question: "What services does Citinet include?",
          answer:
            "Everything you use online: citizen-operated browsers, search engines, social networks, marketplaces, messaging, email, identity systems, and cloud storage. It's the complete online experience, reimagined for citizens.",
        },
        {
          question: "What makes it different?",
          answer:
            "It feels familiar — messaging, sharing, connecting — but everything is local-first, private-by-default, and controlled by the communities who use it.",
        },
        {
          question: "Is this a new Internet?",
          answer:
            "Citinet uses the physical Internet infrastructure, but replaces the centralized platforms dominating it. Instead of corporate search engines, social networks, and marketplaces controlling your experience, citizens operate the infrastructure you use.",
        },
        {
          question: "Who is it for?",
          answer:
            "People who want independence from corporate or government-dominated online platforms and a return to human-centered digital life.",
        },
        {
          question: "How can I be part of it?",
          answer:
            "Join early to stay informed, participate in pilots, and help shape a citizen-owned future.",
        },
      ]}
    />
  </section>

  <section id="early" class="u-container">
    <div class="cta-block">
      <h2 class="u-heading" data-sy-reveal="words">
        Help build the world's first citizen‑owned Internet.
      </h2>
      <p class="u-text" data-sy-reveal="lines">
        Join early to stay informed, participate in pilots, or explore future
        investment opportunities.
      </p>
      <form class="cta-form">
        <input
          type="email"
          placeholder="your@email.com"
          required
          class="cta-input"
        />
        <Button title="Join Early Access" url="#" arrow />
      </form>
    </div>
  </section>

  <GL />
  <GLPlaces />
</Layout>

<style>
  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }

  .cta-block {
    margin: 6rem 0 4rem;
    max-width: 42rem;
  }

  .cta-form {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;

    @media (--mq-phone) {
      flex-direction: column;
      align-items: stretch;
    }
  }

  .cta-input {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(var(--rgb-text), 0.15);
    border-radius: 0.5rem;
    font: inherit;
    background: var(--color-brand-3);
    color: var(--color-text);

    &::placeholder {
      color: var(--color-text-alt);
    }

    &:focus {
      outline: none;
      border-color: var(--color-brand-1);
      box-shadow: 0 0 0 2px rgba(var(--rgb-brand-1), 0.2);
    }
  }

  .research-preview {
    padding: 6rem 0;
    position: relative;
    z-index: 9;
    background: var(--color-bg);
  }

  .research-header {
    max-width: 48rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .research-title {
    --fs: 2.5rem;
    --lh: 1.2;
    margin-bottom: 1rem;

    @media (--mq-phone) {
      --fs: 2rem;
    }
  }

  .research-subtitle {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
    max-width: 40rem;
    margin: 0 auto;
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .research-cta {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  .cases-preview {
    padding: 6rem 0;
    position: relative;
    z-index: 9;
  }

  .cases-header {
    max-width: 48rem;
    margin: 0 auto 4rem;
    text-align: center;
  }

  .cases-title {
    --fs: 2.5rem;
    --lh: 1.2;
    margin-bottom: 1rem;

    @media (--mq-phone) {
      --fs: 2rem;
    }
  }

  .cases-subtitle {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
    max-width: 40rem;
    margin: 0 auto;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
    }
  }

  .cases-cta {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }
</style>
