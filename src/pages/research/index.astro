---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ResearchCard from '../../components/ResearchCard.astro';
import Button from '../../components/Button.astro';

const allResearch = await getCollection('research');
const featuredResearch = allResearch.filter(r => r.data.featured);
const otherResearch = allResearch.filter(r => !r.data.featured);

// Sort by date, newest first
const sortedFeatured = featuredResearch.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const sortedOther = otherResearch.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Research">
  <div class="research-page">
    <section class="hero">
      <div class="u-container">
        <div class="hero-content">
          <h1 class="u-heading hero-title" data-sy-reveal="words">
            Research supporting citizen-owned infrastructure
          </h1>
          <p class="u-text hero-subtitle" data-sy-reveal="lines">
            The problems are documented. Big Tech and Big Government surveillance, environmental damage from centralized data centers, algorithmic manipulation, and the erosion of digital freedom. Here's what the research shows.
          </p>
        </div>
      </div>
    </section>

    <section class="featured-research">
      <div class="u-container">
        <h2 class="u-heading section-title" data-sy-reveal="words">Featured Research</h2>
        <div class="research-grid featured">
          {sortedFeatured.map((researchItem) => (
            <ResearchCard research={researchItem} />
          ))}
        </div>
      </div>
    </section>

    {sortedOther.length > 0 && (
      <section class="all-research">
        <div class="u-container">
          <h2 class="u-heading section-title" data-sy-reveal="words">Additional Research</h2>
          <div class="research-grid">
            {sortedOther.map((researchItem) => (
              <ResearchCard research={researchItem} />
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="cta-section">
      <div class="u-container">
        <div class="cta-content">
          <h2 class="u-heading cta-title" data-sy-reveal="words">
            Problems are clear. Solutions exist.
          </h2>
          <p class="u-text cta-text" data-sy-reveal="lines">
            Citizen-owned infrastructure doesn't solve everything, but it solves the root problem: centralized power. When communities control their own digital spaces, surveillance, exploitation, and manipulation become impossible by design.
          </p>
          <div class="cta-actions">
            <Button title="See How Citinet Works" url="/#vision" arrow />
            <Button title="View Case Studies" url="/cases" color="secondary" />
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .research-page {
    padding-top: 4rem;
  }

  .hero {
    padding: 4rem 0 6rem;
    background: linear-gradient(
      180deg,
      rgba(var(--rgb-brand-3), 0.05) 0%,
      rgba(var(--rgb-bg), 1) 100%
    );
  }

  .hero-content {
    max-width: 48rem;
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    --fs: 3.5rem;
    --lh: 1.1;
    margin-bottom: 1.5rem;

    @media (--mq-phone) {
      --fs: 2.5rem;
    }
  }

  .hero-subtitle {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
    max-width: 42rem;
    margin: 0 auto;
  }

  .featured-research,
  .all-research {
    padding: 4rem 0;
  }

  .section-title {
    --fs: 2rem;
    margin-bottom: 3rem;
    text-align: center;
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;

    @media (--mq-tablet) {
      grid-template-columns: 1fr;
    }

    &.featured {
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));

      @media (--mq-tablet) {
        grid-template-columns: 1fr;
      }
    }
  }

  .cta-section {
    padding: 6rem 0;
    background: linear-gradient(
      180deg,
      rgba(var(--rgb-bg), 1) 0%,
      rgba(var(--rgb-brand-3), 0.05) 50%,
      rgba(var(--rgb-bg), 1) 100%
    );
  }

  .cta-content {
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .cta-title {
    --fs: 2.5rem;
    --lh: 1.2;

    @media (--mq-phone) {
      --fs: 2rem;
    }
  }

  .cta-text {
    --fs: var(--font-size-lg);
    color: var(--color-text-alt);
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;

    @media (--mq-phone) {
      flex-direction: column;
      width: 100%;
    }
  }
</style>
