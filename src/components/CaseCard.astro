---
import type { CollectionEntry } from 'astro:content';

interface Props {
  case: CollectionEntry<'cases'>;
}

const { case: caseStudy } = Astro.props;
const { title, description, community, location, category, status } = caseStudy.data;
---

<a href={`/cases/${caseStudy.slug}`} class="case-card">
  <div class="case-inner">
    <div class="badges">
      <div class="category-badge">{category.replace('-', ' ')}</div>
      {status && status !== 'complete' && (
        <div class={`status-badge status-${status}`}>
          {status === 'ongoing' ? 'Ongoing' : status === 'pilot' ? 'Pilot' : status}
        </div>
      )}
    </div>
    <h3 class="u-heading case-title" data-sy-reveal="words">{title}</h3>
    <p class="u-text case-description" data-sy-reveal="lines">{description}</p>
    <div class="meta">
      <span class="community">{community}</span>
      {location && <span class="location">{location}</span>}
    </div>
    <span class="read-more">Read Case Study →</span>
  </div>
</a>

<style>
  .case-card {
    display: block;
    text-decoration: none;
    border-radius: 1rem;
    background: var(--color-brand-3);
    padding: 2rem;
    transition: all 0.3s var(--ease-out-cubic);
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(var(--rgb-text), 0.08);

    &:hover,
    &:focus {
      border-color: var(--color-brand-1);
    }

    &:hover .read-more {
      transform: translateX(4px);
    }
  }

  .case-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }

  .badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .category-badge {
    display: inline-block;
    width: fit-content;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    background: rgba(var(--rgb-text), 0.05);
    color: var(--color-text-alt);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-badge {
    display: inline-block;
    width: fit-content;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;

    &.status-ongoing {
      background: rgba(var(--rgb-brand-1), 0.15);
      color: var(--color-brand-1);
    }

    &.status-pilot {
      background: rgba(255, 193, 7, 0.15);
      color: #ffc107;
    }
  }

  .case-title {
    --fs: var(--font-size-lg);
    --fw: 600;
    --ls: -0.02em;
    margin: 0;
  }

  .case-description {
    --fs: var(--font-size-sm);
    color: var(--color-text-alt);
    flex: 1;
    margin: 0;
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(var(--rgb-text), 0.1);
    font-size: 0.875rem;

    span {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--color-text-alt);
    }

    .community {
      font-weight: 600;
      color: var(--color-text);
    }

    .location::before {
      content: "";
      margin-right: 0;
    }
  }

  .read-more {
    color: var(--color-brand-1);
    font-weight: 500;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    transition: transform 0.3s var(--ease-out-cubic);
    display: inline-block;
  }
</style>
