---

---

<sy-gl></sy-gl>

<script>
  import * as THREE from "three";
  import gsap from "gsap";
  import { addResizeObserver } from "../utils/observers";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const container = document.querySelector("sy-gl") as HTMLElement;

  const scene = new THREE.Scene();
  const frustumSize = 5;
  let aspect = window.innerWidth / window.innerHeight;
  const camera = new THREE.OrthographicCamera(
    (-frustumSize * aspect) / 2,
    (frustumSize * aspect) / 2,
    frustumSize / 2,
    -frustumSize / 2,
    0,
    10.6,
  );

  camera.position.set(0, 0, 10);
  camera.lookAt(0, 0, 0);
  camera.updateProjectionMatrix();

  const renderer = new THREE.WebGLRenderer({
    antialias: true,
    alpha: true,
  });
  const canvas = renderer.domElement;
  renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  container.appendChild(canvas);

  renderer.setClearColor("#090C02");
  renderer.setClearAlpha(0);

  // ===== REFINED NETWORK GLOBE =====
  const radius = 1;

  // Create node positions using fibonacci sphere for even distribution
  const nodeCount = 42;
  const uniqueNodes: THREE.Vector3[] = [];
  const golden = Math.PI * (3 - Math.sqrt(5));

  for (let i = 0; i < nodeCount; i++) {
    const t = i / (nodeCount - 1);
    const y = 1 - 2 * t;
    const r = Math.sqrt(1 - y * y);
    const phi = i * golden;
    const x = Math.cos(phi) * r;
    const z = Math.sin(phi) * r;
    uniqueNodes.push(new THREE.Vector3(x, y, z).multiplyScalar(radius));
  }

  const globals = {
    uTime: { value: 0 },
    uVel: { value: 0 },
    uResolution: {
      value: new THREE.Vector2(window.innerWidth, window.innerHeight),
    },
  };

  // ===== MAIN GLOBE GROUP =====
  const ballGroup = new THREE.Group();
  const networkGroup = new THREE.Group();
  scene.add(ballGroup);
  ballGroup.add(networkGroup);

  // ===== INNER SPHERE REMOVED - Hyper-minimal design =====
  // No colored inner sphere - wireframe + points only

  // ===== WIREFRAME (Minimal white lines) =====
  const wireframeShader = {
    vertexShader: `
      varying vec3 vPosition;
      varying vec3 vNormal;

      void main() {
        vPosition = position;
        vNormal = normalize(normalMatrix * normal);
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      uniform float uAlpha;

      varying vec3 vPosition;
      varying vec3 vNormal;

      void main() {
        vec3 viewDir = normalize(cameraPosition - vPosition);
        float fresnel = pow(1.0 - abs(dot(viewDir, vNormal)), 1.5);

        vec3 lineColor = vec3(0.945, 0.941, 0.91);  // Soft Linen #F1F0E8
        float alpha = fresnel * 0.18 * uAlpha;

        gl_FragColor = vec4(lineColor, alpha);
      }
    `
  };

  const wireframeMat = new THREE.ShaderMaterial({
    vertexShader: wireframeShader.vertexShader,
    fragmentShader: wireframeShader.fragmentShader,
    uniforms: {
      uTime: globals.uTime,
      uAlpha: { value: 0 },
    },
    transparent: true,
    wireframe: true,
  });

  const wireframeSphere = new THREE.Mesh(
    new THREE.IcosahedronGeometry(radius * 1.002, 2),
    wireframeMat
  );
  networkGroup.add(wireframeSphere);

  // ===== CONNECTION LINES (Minimal static lines) =====
  const connectionShader = {
    vertexShader: `
      attribute float lineAlpha;
      varying float vAlpha;

      void main() {
        vAlpha = lineAlpha;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `,
    fragmentShader: `
      uniform float uAlpha;

      varying float vAlpha;

      void main() {
        vec3 lineColor = vec3(0.627, 0.62, 0.588);  // Muted linen
        float alpha = vAlpha * 0.12 * uAlpha;

        gl_FragColor = vec4(lineColor, alpha);
      }
    `
  };

  // Build connection lines between nearby nodes
  const linePositions: number[] = [];
  const lineAlphas: number[] = [];
  const connectionThreshold = 0.65;

  for (let i = 0; i < uniqueNodes.length; i++) {
    for (let j = i + 1; j < uniqueNodes.length; j++) {
      const dist = uniqueNodes[i].distanceTo(uniqueNodes[j]);
      if (dist < connectionThreshold) {
        linePositions.push(
          uniqueNodes[i].x, uniqueNodes[i].y, uniqueNodes[i].z,
          uniqueNodes[j].x, uniqueNodes[j].y, uniqueNodes[j].z
        );
        const alpha = 1.0 - (dist / connectionThreshold);
        lineAlphas.push(alpha, alpha);
      }
    }
  }

  const lineGeo = new THREE.BufferGeometry();
  lineGeo.setAttribute('position', new THREE.Float32BufferAttribute(linePositions, 3));
  lineGeo.setAttribute('lineAlpha', new THREE.Float32BufferAttribute(lineAlphas, 1));

  const lineMat = new THREE.ShaderMaterial({
    vertexShader: connectionShader.vertexShader,
    fragmentShader: connectionShader.fragmentShader,
    uniforms: {
      uTime: globals.uTime,
      uAlpha: { value: 0 },
    },
    transparent: true,
    depthWrite: false,
  });

  const connectionLines = new THREE.LineSegments(lineGeo, lineMat);
  networkGroup.add(connectionLines);

  // ===== NODE POINTS (Minimal white dots) =====
  const nodeShader = {
    vertexShader: `
      uniform float uScale;

      attribute float nodeIndex;

      varying float vIndex;

      void main() {
        vIndex = nodeIndex;

        vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);

        float size = 5.0 * uScale;

        gl_PointSize = size;
        gl_Position = projectionMatrix * mvPosition;
      }
    `,
    fragmentShader: `
      uniform float uAlpha;

      void main() {
        vec2 center = gl_PointCoord - 0.5;
        float dist = length(center);

        if (dist > 0.5) discard;

        float alpha = smoothstep(0.5, 0.1, dist);

        vec3 color = vec3(0.945, 0.941, 0.91);  // Soft Linen #F1F0E8

        alpha *= 0.7 * uAlpha;

        gl_FragColor = vec4(color, alpha);
      }
    `
  };

  const nodePointsGeo = new THREE.BufferGeometry();
  const nodePointPositions: number[] = [];
  const nodeIndices: number[] = [];

  uniqueNodes.forEach((node, i) => {
    nodePointPositions.push(node.x, node.y, node.z);
    nodeIndices.push(i);
  });

  nodePointsGeo.setAttribute('position', new THREE.Float32BufferAttribute(nodePointPositions, 3));
  nodePointsGeo.setAttribute('nodeIndex', new THREE.Float32BufferAttribute(nodeIndices, 1));

  const nodePointsMat = new THREE.ShaderMaterial({
    vertexShader: nodeShader.vertexShader,
    fragmentShader: nodeShader.fragmentShader,
    uniforms: {
      uTime: globals.uTime,
      uAlpha: { value: 0 },
      uScale: { value: 1 },
    },
    transparent: true,
    depthWrite: false,
  });

  const nodePoints = new THREE.Points(nodePointsGeo, nodePointsMat);
  networkGroup.add(nodePoints);

  // ===== OUTER ATMOSPHERE REMOVED - Hyper-minimal design =====
  // No glow effects

  // ===== ANIMATION =====
  window.scrollVelocity = 0;
  window.scrollDirection = 1;
  window.scrollCurrent = 0;
  window.scrollStickyOffsets = window.scrollStickyOffsets || [];

  let smoothVel = 0;
  let pixelToUnit = -frustumSize / window.innerHeight;
  let isPlaced = true;

  function animate(t: number) {
    globals.uTime.value = t * 1000;

    const vel = isPlaced ? 0 : window.scrollVelocity;
    const abs = Math.abs(vel);
    const dir = window.scrollDirection;

    // Smooth, elegant rotation
    networkGroup.rotation.y += (0.0008 + abs * 0.0004) * dir;
    networkGroup.rotation.x += (0.0004 + abs * 0.0002) * -dir;

    smoothVel += (abs - smoothVel) * 0.05;
    globals.uVel.value = smoothVel;
    camera.position.y = window.scrollCurrent * pixelToUnit;

    renderer.render(scene, camera);
  }

  gsap.ticker.fps(60);
  gsap.ticker.add(animate);

  // ===== INTRO ANIMATION =====
  networkGroup.scale.setScalar(0);

  function animateIn() {
    const ease = "expo.out";
    const duration = 1.2;

    gsap.to(networkGroup.scale, {
      x: 1,
      y: 1,
      z: 1,
      duration,
      ease,
    });

    gsap.to(wireframeMat.uniforms.uAlpha, {
      value: 1,
      duration: duration * 0.8,
      delay: 0.1,
      ease: "power2.out",
    });

    gsap.to(lineMat.uniforms.uAlpha, {
      value: 1,
      duration: duration,
      delay: 0.15,
      ease: "power2.out",
    });

    gsap.to(nodePointsMat.uniforms.uAlpha, {
      value: 1,
      duration: duration,
      delay: 0.2,
      ease: "power2.out",
    });
  }

  setTimeout(animateIn, 200);

  // ===== CUSTOM ELEMENT =====
  class SyGL extends HTMLElement {
    height = 0;
    width = 0;
    tl: ReturnType<typeof gsap.timeline> | null = null;

    connectedCallback() {
      const placeholders = Array.from(
        document.querySelectorAll<HTMLElement>("[data-gl-place]"),
      );

      const getPosData = (el: HTMLElement) => {
        if (!positions.has(el)) {
          const { top: _top, left, width, height } = el.getBoundingClientRect();
          const top = _top + window.scrollY;

          const centerX = left + width / 2;
          const centerY = top + height / 2;

          const pixelToUnitX = (frustumSize * aspect) / this.width;
          const pixelToUnitY = frustumSize / this.height;

          const factor = parseFloat(
            el.getAttribute("data-gl-place-factor") || "1",
          );

          const sticky = el.hasAttribute("data-gl-place-sticky");

          positions.set(el, {
            x: (centerX - this.width / 2) * pixelToUnitX,
            y: -(centerY - this.height / 2) * pixelToUnitY,
            scale: width * pixelToUnitX * 0.5,
            factor,
            sticky,
          });
        }

        return positions.get(el);
      };

      let positions = new WeakMap();

      const tl = gsap.timeline({
        defaults: {
          ease: "none",
        },
        scrollTrigger: {
          trigger: this,
          scrub: true,
          invalidateOnRefresh: true,
          fastScrollEnd: true,
          onRefresh: () => {
            positions = new WeakMap();
            setFirst();
          },
          start: () => `${Math.round(window.innerHeight / 2)}px center`,
          end: () => {
            const last =
              placeholders[placeholders.length - 1]?.getBoundingClientRect();
            if (!last) return `+=${window.innerHeight}px bottom`;
            return `+=${Math.round(last.top + window.scrollY)}px bottom`;
          },
        },
      });

      const setFirst = () => {
        const first = placeholders[0];
        if (!first) return;
        const data = getPosData(first);
        ballGroup.position.x = data.x;
        ballGroup.position.y = data.y;
        ballGroup.scale.setScalar(data.scale);
      };

      tl.add(() => {
        setFirst();
      });

      placeholders.forEach((hldr, i) => {
        const prev = placeholders[i - 1];

        if (!prev) {
          return;
        }

        const duration = () => {
          const p = getPosData(prev);
          const h = getPosData(hldr);

          var b = p.y - h.y;
          var c = Math.round(Math.sqrt(b * b) * 10);

          return c * p.factor;
        };

        tl.to(ballGroup.position, {
          duration,
          x: () => getPosData(hldr).x,
          y: () => getPosData(hldr).y,
        });

        tl.to(
          ballGroup.scale,
          {
            duration,
            x: () => getPosData(hldr).scale,
            y: () => getPosData(hldr).scale,
            z: () => getPosData(hldr).scale,
            onUpdate() {
              const prg = this.progress();

              if (prg === 0 || prg === 1) {
                isPlaced = true;
              } else if (isPlaced) {
                isPlaced = false;
              }
            },
          },
          "<",
        );
      });

      this.tl = tl;

      const resizeObserver = new ResizeObserver(() => {
        tl.scrollTrigger?.refresh();
      });
      resizeObserver.observe(document.body);
    }

    constructor() {
      super();

      addResizeObserver(this);

      this.onResize();
    }

    onResize = () => {
      const width = window.innerWidth;
      const height = window.innerHeight;

      this.width = width;
      this.height = height;

      pixelToUnit = -frustumSize / height;

      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
      renderer.setSize(width, height);

      globals.uResolution.value.x = canvas.width;
      globals.uResolution.value.y = canvas.height;

      aspect = width / height;
      camera.left = (-frustumSize * aspect) / 2;
      camera.right = (frustumSize * aspect) / 2;
      camera.top = frustumSize / 2;
      camera.bottom = -frustumSize / 2;
      camera.updateProjectionMatrix();

      this.tl?.scrollTrigger?.refresh();
    };

    getTotalStickyOffset(scrollY: number): [number, number] {
      let cameraOffset = 0;
      let sceneOffset = 0;

      window.scrollStickyOffsets.forEach(([start, end, current]) => {
        if (scrollY < start) {
          return;
        } else if (scrollY >= start && scrollY <= end) {
          cameraOffset += current;
          sceneOffset -= current;
        } else {
          cameraOffset = current;
        }
      });

      return [cameraOffset, sceneOffset];
    }
  }

  customElements.define("sy-gl", SyGL);
</script>

<style>
  sy-gl {
    position: fixed;
    z-index: 8;
    pointer-events: none;
    top: 0;
    left: 0;
  }
</style>
