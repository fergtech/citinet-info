---
import '../styles/index.css';

interface Props {
  title?: string;
}

const { title = 'Citinet — Citizens\' Internet Project' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Citinet — Citizens' Internet Project" />
    <meta property="og:description" content="A movement for digital sovereignty. Build, own, and connect your community's internet." />
    <meta property="og:image" content="/logo.png" />
    <meta property="og:image:alt" content="Citinet Logo" />
    <meta property="og:url" content="https://citinet.cloud/" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Citinet — Citizens' Internet Project" />
    <meta name="twitter:description" content="A movement for digital sovereignty. Build, own, and connect your community's internet." />
    <meta name="twitter:image" content="/logo.png" />
    <meta name="twitter:image:alt" content="Citinet Logo" />
  </head>
  <body>
    <slot />
  </body>
</html>
